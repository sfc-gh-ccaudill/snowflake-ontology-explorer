# ---------------------------------------------------------------------------
# ontology demo — deployment configuration
#
# Copy this file to `config.env` and edit to deploy into YOUR account with YOUR
# database names. `config.env` is git-ignored; this *.example file is committed.
#
#   cp config.env.example config.env
#   # edit config.env, then:
#   ./deploy.sh
#
# If you DON'T create config.env, ./deploy.sh falls back to these defaults,
# which reproduce the reference deployment exactly (byte-for-byte).
# ---------------------------------------------------------------------------

# Which connection in ~/.snowflake/connections.toml to deploy with.
# Set this to YOUR connection name — run `snow connection list` to see them.
# `DEMO` is just the reference default and probably does NOT exist in your setup.
# Must be a role that can CREATE DATABASE (e.g. SYSADMIN).
SNOWFLAKE_CONNECTION=DEMO
BUILD_ROLE=SYSADMIN
WAREHOUSE=COMPUTE_WH

# --- Source system 1: clinical EMR -----------------------------------------
EMR_DB=CLINICAL_EMR
EMR_SCHEMA=EHR

# --- The ontology layer (built on top of the EMR database) ------------------
# ONTOLOGY_DB defaults to EMR_DB because the ontology is a schema *inside* the
# EMR database. Only change this if you deliberately want it elsewhere.
ONTOLOGY_DB=${EMR_DB}
ONTOLOGY_SCHEMA=ONTOLOGY

# --- Source system 2: payer claims -----------------------------------------
CLAIMS_DB=PAYER_CLAIMS
CLAIMS_SCHEMA=CLAIMS

# --- Source system 3: pharmacy ops ------------------------------------------
RX_DB=PHARMACY_OPS
RX_SCHEMA=RX
