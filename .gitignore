# ---------------------------------------------------------------------------
# Dependencies — never commit; restored via `npm install` / `npm run install:all`
# ---------------------------------------------------------------------------
node_modules/
**/node_modules/

# ---------------------------------------------------------------------------
# Build / rendered output
# ---------------------------------------------------------------------------
# ./build holds SQL rendered by deploy.sh
build/
dist/
**/dist/
.vite/
**/.vite/

# ---------------------------------------------------------------------------
# Secrets & local config — commit only the *.example templates
# ---------------------------------------------------------------------------
.env
**/.env
*.local
# local deploy overrides; commit config.env.example instead
config.env

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
npm-debug.log*

# ---------------------------------------------------------------------------
# OS / editor cruft
# ---------------------------------------------------------------------------
.DS_Store

# ---------------------------------------------------------------------------
# Cortex Code IDE local working artifacts (plans, session state)
# ---------------------------------------------------------------------------
.snowflake/
