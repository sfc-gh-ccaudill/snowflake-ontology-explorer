# ---------------------------------------------------------------------------
# ontology-explorer server configuration (all optional)
# Copy to .env and adjust as needed. Sensible defaults are used if unset.
# ---------------------------------------------------------------------------

# Port the Express API listens on (frontend dev server proxies /api here).
PORT=3001

# Which connection to read from ~/.snowflake/connections.toml
SNOWFLAKE_CONNECTION_NAME=DEMO

# Override the path to connections.toml if it is not in the default location.
# SNOWFLAKE_CONNECTIONS_TOML=/Users/you/.snowflake/connections.toml

# ---------------------------------------------------------------------------
# Database / schema names (all optional). Defaults reproduce the reference
# deployment. Set these ONLY if you deployed the demo under different names
# (i.e. you changed them in the repo's config.env before running ./deploy.sh).
# ---------------------------------------------------------------------------
# EMR_DB=CLINICAL_EMR
# EMR_SCHEMA=EHR
# ONTOLOGY_DB=CLINICAL_EMR        # defaults to EMR_DB
# ONTOLOGY_SCHEMA=ONTOLOGY
# CLAIMS_DB=PAYER_CLAIMS
# CLAIMS_SCHEMA=CLAIMS
# RX_DB=PHARMACY_OPS
# RX_SCHEMA=RX

# ---------------------------------------------------------------------------
# Cortex Agent (not yet available — leave unset until the agent exists).
# When set, /api/chat calls the real agent. When unset, /api/chat returns a
# clearly-labelled placeholder response so the UI is fully usable today.
# Fully-qualified agent name, e.g. MY_DB.MY_SCHEMA.MY_AGENT
# ---------------------------------------------------------------------------
# CORTEX_AGENT_NAME=
